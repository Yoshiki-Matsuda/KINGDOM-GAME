# 開発時のみ。true にするとサーバー/DBに接続せず、仮のマスデータ（48x48）でマップを表示します。
# コピーして .env または .env.local にし、必要に応じて有効にしてください。
# VITE_USE_MOCK_STATE=true

# npm run dev 時に自動ログイン（デフォルト有効。false でログインモーダル表示）
# VITE_DEV_AUTO_LOGIN=true
# VITE_DEV_USERNAME=offline_test
# VITE_DEV_PASSWORD=test12345

# 地形イラストを無効にし、色のみで描画します。重いときは false にすると軽くなります。
# VITE_USE_TERRAIN_IMAGES=true

# サーバー側: 開発用敵BOT（既存 /auth/login + /ws のみ。DEV_AUTO_WIN=1 でも自動起動）
# DEV_BOT=1
# DEV_BOT_USERNAME=player
# DEV_BOT_TARGET=offline_test
# DEV_BOT_INTERVAL_SEC=45
